{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vehiclesense.local/schemas/event-v1.schema.json",
  "title": "VehicleSense device event v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "message_type", "event_id", "device_id", "vehicle_id",
    "event_type", "severity", "uptime_ms", "time_valid", "simulated"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "message_type": { "const": "event" },
    "event_id": { "type": "string", "minLength": 5, "maxLength": 170, "pattern": "^[A-Za-z0-9._:-]+$" },
    "device_id": { "$ref": "#/$defs/id" },
    "vehicle_id": { "$ref": "#/$defs/id" },
    "event_type": {
      "enum": [
        "sensor_invalid", "gps_invalid", "storage_failure", "offline_data_dropped",
        "microphone_failure", "microphone_clipping", "acoustic_traffic",
        "acoustic_horn", "acoustic_siren", "temperature_high", "temperature_low",
        "acceleration_candidate", "vibration_candidate", "system_warning"
      ]
    },
    "severity": { "enum": ["info", "low", "medium", "high", "critical"] },
    "uptime_ms": { "type": "integer", "minimum": 0, "maximum": 9007199254740991 },
    "time_valid": { "type": "boolean" },
    "occurred_at": { "type": "string", "format": "date-time" },
    "duration_ms": { "type": "integer", "minimum": 0 },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "details": { "type": "object", "maxProperties": 20 },
    "simulated": { "type": "boolean" }
  },
  "$defs": {
    "id": { "type": "string", "minLength": 1, "maxLength": 64, "pattern": "^[A-Za-z0-9._-]+$" }
  },
  "allOf": [
    {
      "if": { "properties": { "time_valid": { "const": true } }, "required": ["time_valid"] },
      "then": { "required": ["occurred_at"] },
      "else": { "not": { "required": ["occurred_at"] } }
    }
  ]
}
