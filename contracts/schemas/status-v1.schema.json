{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vehiclesense.local/schemas/status-v1.schema.json",
  "title": "VehicleSense device status v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "message_type", "device_id", "vehicle_id",
    "state", "reason", "simulated"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "message_type": { "const": "status" },
    "device_id": { "$ref": "#/$defs/id" },
    "vehicle_id": { "$ref": "#/$defs/id" },
    "boot_id": { "type": "integer", "minimum": 0, "maximum": 4294967295 },
    "state": { "enum": ["online", "offline", "reconnecting"] },
    "reason": {
      "enum": ["connected", "unexpected_disconnect", "network_lost", "broker_unavailable", "shutdown", "unknown"]
    },
    "firmware_version": { "type": "string", "minLength": 1, "maxLength": 40 },
    "uptime_ms": { "type": "integer", "minimum": 0, "maximum": 9007199254740991 },
    "time_valid": { "type": "boolean" },
    "observed_at": { "type": "string", "format": "date-time" },
    "wifi_rssi_dbm": { "type": "integer", "minimum": -127, "maximum": 0 },
    "ip_address": { "type": "string", "format": "ipv4" },
    "simulated": { "type": "boolean" }
  },
  "$defs": {
    "id": {
      "type": "string", "minLength": 1, "maxLength": 64,
      "pattern": "^[A-Za-z0-9._-]+$"
    }
  },
  "allOf": [
    {
      "if": { "properties": { "time_valid": { "const": true } }, "required": ["time_valid"] },
      "then": { "required": ["observed_at"] },
      "else": { "not": { "required": ["observed_at"] } }
    },
    {
      "if": { "properties": { "state": { "const": "offline" } }, "required": ["state"] },
      "then": { "not": { "anyOf": [{ "required": ["wifi_rssi_dbm"] }, { "required": ["ip_address"] }] } },
      "else": {}
    }
  ]
}
