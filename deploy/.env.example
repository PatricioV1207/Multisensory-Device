COMPOSE_PROJECT_NAME=vehiclesense
DOMAIN=vehiclesense.example.com
LETSENCRYPT_EMAIL=admin@example.com
NGINX_TEMPLATE=http.conf.template

POSTGRES_DB=vehiclesense
POSTGRES_USER=vehiclesense
POSTGRES_PASSWORD=REPLACE_WITH_URL_SAFE_RANDOM_HEX

VEHICLESENSE_JWT_SECRET=REPLACE_WITH_AT_LEAST_32_RANDOM_CHARACTERS
VEHICLESENSE_BOOTSTRAP_ADMIN_EMAIL=admin@example.com
VEHICLESENSE_BOOTSTRAP_ADMIN_PASSWORD=REPLACE_WITH_AT_LEAST_12_CHARACTERS

VEHICLESENSE_MQTT_HOST=YOUR_CLUSTER.s1.eu.hivemq.cloud
VEHICLESENSE_MQTT_PORT=8883
VEHICLESENSE_MQTT_USERNAME=YOUR_BACKEND_USER
VEHICLESENSE_MQTT_PASSWORD=YOUR_BACKEND_PASSWORD
VEHICLESENSE_MQTT_CLIENT_ID=vehiclesense-backend-production-01
VEHICLESENSE_MQTT_TOPIC_PREFIX=vehiclesense/v1

VEHICLESENSE_STALE_AFTER_SECONDS=45
VEHICLESENSE_OFFLINE_AFTER_SECONDS=120
VEHICLESENSE_STATUS_SCAN_SECONDS=15
VEHICLESENSE_AUTO_REGISTER_DEVICES=false
