VEHICLESENSE_ENVIRONMENT=development
VEHICLESENSE_DATABASE_URL=postgresql+asyncpg://vehiclesense:CHANGE_ME@postgres:5432/vehiclesense
VEHICLESENSE_AUTO_CREATE_SCHEMA=false
VEHICLESENSE_CORS_ORIGINS=["http://localhost:5173"]

VEHICLESENSE_JWT_SECRET=REPLACE_WITH_AT_LEAST_32_RANDOM_CHARACTERS
VEHICLESENSE_ACCESS_TOKEN_MINUTES=15
VEHICLESENSE_REFRESH_TOKEN_DAYS=7
VEHICLESENSE_BOOTSTRAP_ADMIN_EMAIL=
VEHICLESENSE_BOOTSTRAP_ADMIN_PASSWORD=

VEHICLESENSE_MQTT_ENABLED=true
VEHICLESENSE_MQTT_HOST=YOUR_CLUSTER.s1.eu.hivemq.cloud
VEHICLESENSE_MQTT_PORT=8883
VEHICLESENSE_MQTT_USERNAME=YOUR_BACKEND_USER
VEHICLESENSE_MQTT_PASSWORD=YOUR_BACKEND_PASSWORD
VEHICLESENSE_MQTT_CLIENT_ID=vehiclesense-backend-production
VEHICLESENSE_MQTT_TOPIC_PREFIX=vehiclesense/v1
VEHICLESENSE_MQTT_CA_FILE=

VEHICLESENSE_STALE_AFTER_SECONDS=45
VEHICLESENSE_OFFLINE_AFTER_SECONDS=120
VEHICLESENSE_AUTO_REGISTER_DEVICES=false
